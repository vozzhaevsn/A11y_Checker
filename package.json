{
  "name": "a11y-checker-pro",
  "version": "1.0.0",
  "description": "Browser extension for automated accessibility checking based on WCAG standards",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "start": "npm run build:dev"
  },
  "keywords": [
    "accessibility",
    "wcag",
    "a11y",
    "browser-extension",
    "chrome-extension"
  ],
  "author": "Semyon Vozzhaev",
  "license": "MIT",
  "dependencies": {
    "axe-core": "^4.8.0",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.250",
    "@types/jest": "^29.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4"
  }
